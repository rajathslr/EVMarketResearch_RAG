# ── DigitalOcean ──────────────────────────────────────────────────────────
DO_TOKEN=your_do_token_here
DO_SPACES_KEY=your_spaces_key
DO_SPACES_SECRET=your_spaces_secret
DO_SPACES_ENDPOINT=https://blr1.digitaloceanspaces.com
DO_SPACES_BUCKET=ev-research-dl-blr1
DO_SPACES_REGION=blr1

# ── Local data storage ────────────────────────────────────────────────────
LOCAL_DATA_DIR=C:\EVMarketResearch\data

# ── Postgres / pgvector (DigitalOcean Managed Postgres) ───────────────────
DB_HOST=your-cluster.db.ondigitalocean.com
DB_PORT=25060
DB_NAME=ev_research
DB_USER=pipeline
DB_PASSWORD=your_pipeline_password
DATABASE_URL=postgresql://pipeline:password@host:25060/ev_research?sslmode=require
DATABASE_ADMIN_URL=postgresql://doadmin:password@host:25060/ev_research?sslmode=require

# ── Anthropic ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── YouTube Data API v3 ───────────────────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_api_key

# ── Firecrawl ─────────────────────────────────────────────────────────────
FIRECRAWL_API_KEY=fc-...

# ── Optional integrations ─────────────────────────────────────────────────
REDDIT_CLIENT_ID=REPLACE_ME
REDDIT_CLIENT_SECRET=REPLACE_ME
REDDIT_USER_AGENT=ev-research-bot/1.0
APIFY_TOKEN=REPLACE_ME
NEWS_API_KEY=REPLACE_ME
OPENAI_API_KEY=REPLACE_ME

# ── Pipeline settings ─────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=8
LOG_LEVEL=INFO
